# ─── Inference (vendor-independent) ───────────────────────────────────────────
# Default is a self-hosted local OpenAI-compatible LLM (Ollama / llama.cpp).
LOCAL_LLM_BASE_URL=http://ollama:11434/v1
DEFAULT_LLM_MODEL=llama3
OLLAMA_MODEL=llama3
# LOCAL_LLM_API_KEY left as "ollama" placeholder; real keys come from per-user BYOK.
LOCAL_LLM_API_KEY=ollama
# SSRF: explicitly permit the local LLM host (instead of a blanket private bypass).
LOCAL_LLM_HOST=ollama
ALLOW_PRIVATE_OLLAMA=true
# ─── Security (P0): REQUIRED in production — no insecure fallback exists ───────
# BYOK_ENCRYPTION_PASSPHRASE must be >=16 chars or BYOK key operations fail closed.
# Set in Postgres as: ALTER DATABASE <db> SET app.byok_encryption_passphrase = '...';
# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ─── Embeddings (configurable; default keeps OpenAI text-embedding-3-small @1536) ──
# EMBEDDING_PROVIDER: openai (default) | local | ollama | llamacpp
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM must match the pgvector column. Default 1536 (OpenAI).
# For fully-local embeddings (e.g. nomic-embed-text=768) you MUST resize the column
# and re-embed: see scripts/switch-embeddings-to-local.sql.
EMBEDDING_DIM=1536

# ─── Semantic grounding gate (Phase 3; default OFF = no behavior change) ───────
FAITHFULNESS_CHECK=false
FAITHFULNESS_ENGINE=heuristic   # heuristic | nli | llm
FAITHFULNESS_THRESHOLD=0.6
# NLI_ENDPOINT=                 # optional cross-encoder entailment endpoint (nli-deberta-v3)
# NLI_HOST_SUFFIX=              # comma-separated allowed host suffixes for NLI_ENDPOINT
