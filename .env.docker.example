# ── RocketBoard self-host env (copy to .env) ──────────────────────────────────
# Frontend (Vite, build-time — baked into the static build)
VITE_SUPABASE_URL=http://localhost:8000          # your self-hosted Supabase (Kong) URL
VITE_SUPABASE_PUBLISHABLE_KEY=                    # = the Supabase anon key

# ── Edge function env (set these in the Supabase self-host `.env` too) ─────────
# Inference: fully local by default
LOCAL_LLM_BASE_URL=http://ollama:11434/v1
DEFAULT_LLM_MODEL=llama3
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_HOST=ollama
ALLOW_PRIVATE_OLLAMA=true

# Embeddings: default keeps OpenAI 1536 (set OPENAI_API_KEY) OR go fully local:
#   EMBEDDING_PROVIDER=local; EMBEDDING_MODEL=nomic-embed-text; EMBEDDING_DIM=768
#   (then run scripts/switch-embeddings-to-local.sql + a full reindex)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# OPENAI_API_KEY=                                 # only if EMBEDDING_PROVIDER=openai

# Security (REQUIRED — no insecure fallback exists)
BYOK_ENCRYPTION_PASSPHRASE=change-me-min-16-chars-long
ROCKETBOARD_INTERNAL_SECRET=change-me-internal-secret
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret
ALLOWED_ORIGINS=http://localhost:8080

# Optional: semantic faithfulness gate (Phase 3)
FAITHFULNESS_CHECK=false
FAITHFULNESS_ENGINE=heuristic
